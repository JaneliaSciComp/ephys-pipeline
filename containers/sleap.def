# Build instructions:
#
# Step 1 — pack the existing communal conda env (run once on the cluster):
#   conda pack \
#     --prefix /groups/scicompsoft/home/sheppardj/miniconda3/envs/sleap \
#     -o /groups/voigts/voigtslab/submit_a_day/ephys-pipeline/containers/sleap_env.tar.gz
#
# Step 2 — build the container (from the containers/ directory):
#   apptainer build sleap.sif sleap.def
#
# conda-pack install if needed:
#   /groups/scicompsoft/home/sheppardj/miniconda3/envs/sleap/bin/pip install conda-pack

Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu20.04

%files
    # The packed env tarball produced in Step 1 above
    sleap_env.tar.gz /tmp/sleap_env.tar.gz

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -q && apt-get install -y -q \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    mkdir -p /opt/sleap
    tar -xzf /tmp/sleap_env.tar.gz -C /opt/sleap
    rm /tmp/sleap_env.tar.gz
    # Fix any hardcoded paths from the original env location
    /opt/sleap/bin/conda-unpack

%environment
    export PATH=/opt/sleap/bin:$PATH
    export PYTHONPATH=""

%runscript
    exec /opt/sleap/bin/python "$@"
