Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu20.04

%labels
    Description Kilosort4 + SpikeInterface spike-sorting pipeline

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -q && apt-get install -y -q \
        wget \
        bzip2 \
        git \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install Miniconda with Python 3.9
    wget -q https://repo.anaconda.com/miniconda/Miniconda3-py39_24.7.1-0-Linux-x86_64.sh \
        -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/conda
    rm /tmp/miniconda.sh
    export PATH=/opt/conda/bin:$PATH

    # PyTorch 2.4.1 built for CUDA 11.8
    pip install --no-cache-dir \
        torch==2.4.1 \
        --index-url https://download.pytorch.org/whl/cu118

    # Pipeline packages (pinned to match sorting_env.yml)
    pip install --no-cache-dir \
        spikeinterface==0.103.2 \
        kilosort==4.1.1 \
        probeinterface==0.2.24 \
        numba==0.60.0 \
        pandas==2.2.3 \
        scipy \
        joblib \
        huggingface_hub==1.4.0 \
        skops==0.13.0

%environment
    export PATH=/opt/conda/bin:$PATH
    export PYTHONPATH=""

%runscript
    exec /opt/conda/bin/python "$@"
